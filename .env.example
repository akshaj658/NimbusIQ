# NimbusIQ Environment Configuration
# Copy this file to .env and fill in your values

# Flask secret key - use a long, random string in production
SECRET_KEY=your-secret-key-here

# Path to the SQLite database file
DATABASE_PATH=nimbusiq.db

# Enable/disable the admin panel (true/false)
SHOW_ADMIN=true

# Admin panel credentials
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# INR conversion rate (set to 1.0 for no conversion)
INR_RATE=1.0
