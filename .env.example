# StadiumIQ — FIFA World Cup 2026 Smart Stadium Operations Platform
# Environment Configuration
# Copy this file to .env and fill in your values

# Flask secret key - use a long, random string in production
SECRET_KEY=your-secret-key-here

# Path to the SQLite database file
DATABASE_PATH=stadiumiq.db

# Enable/disable the admin panel (true/false)
SHOW_ADMIN=true

# Admin panel credentials (Basic HTTP Auth)
ADMIN_USER=admin
ADMIN_PASS=your-secure-password-here

# INR conversion rate (set to 1.0 for no additional conversion)
INR_RATE=1.0

# Google Gemini API key for AI-powered stadium operations recommendations
# Get your key at: https://aistudio.google.com/app/apikey
# If not set, StadiumIQ uses smart scenario-based fallback recommendations
GEMINI_API_KEY=your-gemini-api-key-here
